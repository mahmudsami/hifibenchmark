FROM --platform=linux/amd64 ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
        git \
        build-essential \
        zlib1g-dev \
    && rm -rf /var/lib/apt/lists/*

# Clone and build BLEND (CMU-SAFARI)
RUN git clone --depth 1 https://github.com/CMU-SAFARI/BLEND /opt/blend \
    && cd /opt/blend \
    && make \
    && cp bin/blend /usr/local/bin/blend

ENTRYPOINT ["blend"]
